<style>
  .btn-search{
    background-color: #fe424d;
    color: white;
    border-radius: 40px;
    padding: 0 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    white-space: nowrap;
  }
  .btn-search:hover{
    background-color: #fe424d;
    color: white;
  }
  .btn-search i{
    margin-right: 0.5rem;
  }
  .search-input{
    border-radius: 25px;
    padding: 0.5rem 3rem;
  }
  .d-flex{
  flex-wrap: nowrap;
}

/* 📱 MOBILE RESPONSIVE */
@media (max-width: 768px){

  /* Reduce search input size */
  .search-input{
    width: 120px;
    padding: 0.3rem 0.6rem;
    font-size: 0.8rem;
  }

  /* Make button smaller */
  .btn-search{
    padding: 0.3rem 0.6rem;
    font-size: 0.8rem;
  }

  /* Hide text, keep only icon */
  .btn-search span,
  .btn-search::after{
    display: none;
  }

  /* Navbar spacing fix */
  .navbar-nav{
    text-align: center;
  }
}
</style>

<nav class="navbar navbar-expand-md border-bottom sticky-top">
  <div class="container-fluid">

    <a class="navbar-brand" href="/listings">
      <i class="fa-regular fa-compass"></i>
    </a>

    <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNav">

      <div class="navbar-nav">
        <a class="nav-link" href="/listings">Explore</a>
      </div>

      <div class="navbar-nav ms-auto">
        <form class="d-flex">
          <input class="form-control me-2 search-input" type="search" placeholder="Search destinations">
          <button class="btn btn-search">
            <i class="fa-solid fa-magnifying-glass"></i>Search
          </button>
        </form>
      </div>

      <div class="navbar-nav ms-auto">
        <a class="nav-link" href="/listings/new">Airbnb your home</a>

        <% if(!currUser) { %>
          <a class="nav-link" href="/signup"><b>Sign Up</b></a>
          <a class="nav-link" href="/login"><b>Log In</b></a>
        <% } %>

        <% if(currUser) { %>
          <a class="nav-link" href="/logout"><b>Log out</b></a>
        <% } %>
      </div>

    </div>
  </div>
</nav>